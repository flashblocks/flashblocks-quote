{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "flashblocks/quote",
	"version": "0.1.0",
	"title": "Flashblocks Quote",
	"category": "text",
	"icon": "format-quote",
	"description": "Displays a quote with author name, role, and photo. Works standalone or inside a Query Loop.",
	"keywords": [ "quote", "quotes", "testimonial", "blockquote", "flashblocks" ],
	"textdomain": "flashblocks-quotes",
	"attributes": {
		"selectedPostId": {
			"type": "integer",
			"default": 0
		}
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ],
		"color": {
			"gradients": true,
			"heading": true,
			"button": true,
			"link": true,
			"__experimentalDefaultControls": {
				"background": true,
				"text": true
			}
		},
		"shadow": true,
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true,
			"__experimentalDefaultControls": {
				"padding": true
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": true,
				"radius": true,
				"style": true,
				"width": true
			}
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		}
	},
	"example": {
		"attributes": {
			"selectedPostId": 0
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
